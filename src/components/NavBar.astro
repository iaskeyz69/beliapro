---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About Us' },
  { href: '/programs', label: 'Programs' },
  { href: '/news', label: 'News & Media' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string) {
  const normalized = href.replace(/\/$/, '') || '/';
  if (normalized === '/') return currentPath === '/';
  return currentPath === normalized || currentPath.startsWith(`${normalized}/`);
}
---

<nav id="main-nav" class="fixed top-0 w-full z-50 bg-black/60 backdrop-blur-3xl border-b border-white/10 transition-all duration-300">
  <div
    class="flex justify-between items-center px-6 md:px-8 h-16 max-w-screen-2xl mx-auto font-['Plus_Jakarta_Sans'] font-medium tracking-tight"
  >
    <a href="/" class="text-xl font-bold tracking-tighter text-white z-50">BELIAPRO</a>

    <div class="hidden md:flex items-center gap-8">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'transition-colors duration-300',
              isActive(link.href)
                ? 'text-white font-semibold'
                : 'text-white/60 hover:text-white',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-3 z-50">
      <a
        href="/contact"
        class="hidden sm:inline-block bg-primary-container text-on-primary-container px-6 py-2 rounded-full font-bold scale-95 active:scale-90 transition-transform"
      >
        Join Us
      </a>

      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Toggle menu"
        class="md:hidden text-white p-2 rounded-lg hover:bg-white/10 transition-colors"
      >
        <span id="menu-icon-open" class="material-symbols-outlined text-2xl">menu</span>
        <span id="menu-icon-close" class="material-symbols-outlined text-2xl hidden">close</span>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-white/10 bg-black/95 backdrop-blur-3xl"
  >
    <div class="flex flex-col px-6 py-6 gap-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'py-2 text-lg transition-colors',
              isActive(link.href) ? 'text-white font-semibold' : 'text-white/60 hover:text-white',
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/contact"
        class="mt-2 bg-primary-container text-on-primary-container px-6 py-3 rounded-full font-bold text-center"
      >
        Join Us
      </a>
    </div>
  </div>
</nav>

<script>
  function initNav() {
    const nav = document.getElementById('main-nav');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    if (!nav || !menuBtn || !mobileMenu) return;

    const onScroll = () => {
      if (window.scrollY > 50) {
        nav.classList.add('nav-scrolled');
      } else {
        nav.classList.remove('nav-scrolled');
      }
    };

    window.removeEventListener('scroll', onScroll);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    menuBtn.onclick = () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden', isOpen);
      iconOpen?.classList.toggle('hidden', !isOpen);
      iconClose?.classList.toggle('hidden', isOpen);
    };
  }

  initNav();
  document.addEventListener('astro:page-load', initNav);
</script>
