---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/Reveal.astro';

const clubAddress = 'Al-Madrasatul Ittifaqiyah, Jalan Keramat Hujung, Kampung Datuk Keramat, 54000 Kuala Lumpur';
const mapsQuery = encodeURIComponent(clubAddress);
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;
const mapsEmbedUrl = `https://maps.google.com/maps?q=${mapsQuery}&hl=en&z=15&output=embed`;
const web3formsKey =
  import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ||
  import.meta.env.WEB3FORMS_ACCESS_KEY ||
  '';
---

<Layout title="Contact | BELIAPRO" description="Get in touch with Kelab Belia Progresif Datuk Keramat — join our youth programmes or enquire about membership." image="/images/contact.png">
  <main>
    <section class="min-h-[70vh] md:min-h-screen flex flex-col items-center justify-center pt-16 px-margin-mobile">
      <Reveal>
        <div class="text-center max-w-4xl">
          <span class="font-label-caps text-label-caps text-primary-container mb-stack-md block">GET IN TOUCH</span>
          <h1 class="text-display-responsive text-white mb-stack-lg leading-none">Contact Us.</h1>
          <p class="font-body-lg text-body-lg text-secondary max-w-2xl mx-auto">
            Interested in joining BELIAPRO or learning more about our programmes? Reach out to the
            Executive Committee — we'd love to hear from you.
          </p>
        </div>
      </Reveal>
      <div class="mt-section-gap w-full flex justify-center">
        <span class="material-symbols-outlined text-white/20 text-5xl animate-bounce">expand_more</span>
      </div>
    </section>

    <section class="min-h-[70vh] md:min-h-screen flex items-center justify-center py-section-gap px-margin-mobile bg-surface-container-lowest">
      <Reveal>
        <div class="w-full max-w-2xl">
          <div class="glass-card p-12 rounded-[40px]" style="backdrop-filter: blur(30px); background: rgba(26, 26, 26, 0.4);">
            <form id="contact-form" class="space-y-stack-lg">
              <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
              <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-lg">
                <div class="space-y-stack-sm">
                  <label class="font-label-caps text-label-caps text-secondary ml-4">FULL NAME</label>
                  <input
                    class="w-full bg-surface-container border border-white/5 rounded-xl px-6 py-4 focus:border-primary-container focus:ring-0 transition-all outline-none text-white font-body-md"
                    placeholder="Your name"
                    type="text"
                    name="name"
                    required
                  />
                </div>
                <div class="space-y-stack-sm">
                  <label class="font-label-caps text-label-caps text-secondary ml-4">EMAIL ADDRESS</label>
                  <input
                    class="w-full bg-surface-container border border-white/5 rounded-xl px-6 py-4 focus:border-primary-container focus:ring-0 transition-all outline-none text-white font-body-md"
                    placeholder="you@email.com"
                    type="email"
                    name="email"
                    required
                  />
                </div>
              </div>
              <div class="space-y-stack-sm">
                <label class="font-label-caps text-label-caps text-secondary ml-4">ENQUIRY TYPE</label>
                <select
                  class="w-full bg-surface-container border border-white/5 rounded-xl px-6 py-4 focus:border-primary-container focus:ring-0 transition-all outline-none text-white font-body-md appearance-none"
                  name="inquiry"
                >
                  <option>Membership Application</option>
                  <option>Programme Enquiry</option>
                  <option>Volunteer / Partnership</option>
                  <option>Media & Press</option>
                  <option>General Enquiry</option>
                </select>
              </div>
              <div class="space-y-stack-sm">
                <label class="font-label-caps text-label-caps text-secondary ml-4">YOUR MESSAGE</label>
                <textarea
                  class="w-full bg-surface-container border border-white/5 rounded-xl px-6 py-4 focus:border-primary-container focus:ring-0 transition-all outline-none text-white font-body-md resize-none"
                  placeholder="Tell us how we can help..."
                  rows="5"
                  name="message"
                  required
                ></textarea>
              </div>
              <button
                id="contact-submit"
                class="w-full bg-primary-container text-on-primary py-5 rounded-full font-headline-md text-body-md uppercase tracking-widest font-bold hover:brightness-110 active:scale-[0.98] transition-all disabled:opacity-50 disabled:cursor-not-allowed"
                type="submit"
              >
                Send Message
              </button>
              <p id="form-status" class="font-body-md text-center min-h-[1.5rem]" role="status" aria-live="polite"></p>
            </form>
          </div>
        </div>
      </Reveal>
    </section>

    <section class="min-h-[70vh] md:min-h-screen flex items-center justify-center py-section-gap px-margin-mobile">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter max-w-7xl w-full">
        <Reveal>
          <a
            href={mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="relative block overflow-hidden rounded-[40px] aspect-square md:aspect-video glass-card group hover:border-primary-container/30 transition-colors"
            aria-label="Open BELIAPRO location in Google Maps"
          >
            <iframe
              title="BELIAPRO location map"
              src={mapsEmbedUrl}
              class="absolute inset-0 w-full h-full border-0 pointer-events-none grayscale-[30%] group-hover:grayscale-0 transition-all duration-500"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            <div class="absolute bottom-10 left-10 right-10">
              <span class="font-label-caps text-label-caps text-primary-container block mb-2">LOCATION</span>
              <h3 class="text-headline-md-responsive text-white">Kampung Datuk Keramat, KL</h3>
              <p class="font-body-md text-white/60 mt-2 flex items-center gap-2 group-hover:text-primary-container transition-colors">
                <span class="material-symbols-outlined text-lg">location_on</span>
                Open in Google Maps
              </p>
            </div>
          </a>
        </Reveal>
        <Reveal delay={150} class="flex flex-col justify-center gap-stack-lg pl-0 md:pl-12">
          <div class="space-y-stack-sm">
            <span class="font-label-caps text-label-caps text-secondary">CLUB ADDRESS</span>
            <p class="text-headline-md-responsive text-white leading-tight">
              Kelab Belia Progresif Datuk Keramat<br />
              Al-Madrasatul Ittifaqiyah<br />
              Jalan Keramat Hujung<br />
              Kampung Datuk Keramat<br />
              54000 Kuala Lumpur
            </p>
          </div>
          <div class="h-px w-24 bg-white/10"></div>
          <div class="flex flex-col gap-stack-md">
            <span class="font-label-caps text-label-caps text-secondary">FOLLOW US</span>
            <div class="flex flex-wrap gap-8">
              <a class="font-body-lg text-body-lg text-white hover:text-primary-container transition-colors flex items-center gap-2" href="#">
                <span class="material-symbols-outlined">alternate_email</span> Instagram
              </a>
              <a class="font-body-lg text-body-lg text-white hover:text-primary-container transition-colors flex items-center gap-2" href="#">
                <span class="material-symbols-outlined">terminal</span> Facebook
              </a>
              <a class="font-body-lg text-body-lg text-white hover:text-primary-container transition-colors flex items-center gap-2" href="#">
                <span class="material-symbols-outlined">work</span> TikTok
              </a>
            </div>
          </div>
        </Reveal>
      </div>
    </section>
  </main>
</Layout>

<script define:vars={{ web3formsKey }}>
  function initContactForm() {
    const form = document.getElementById('contact-form');
    const status = document.getElementById('form-status');
    const submitBtn = document.getElementById('contact-submit');

    if (!form || !status || !submitBtn) return;

    const onSubmit = async (event) => {
      event.preventDefault();

      if (!web3formsKey) {
        status.textContent = 'Contact form is not configured yet. Please try again later.';
        status.className = 'font-body-md text-center min-h-[1.5rem] text-red-400';
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      status.textContent = '';
      status.className = 'font-body-md text-center min-h-[1.5rem]';

      const formData = new FormData(form);
      formData.append('access_key', web3formsKey);
      formData.append('subject', `BELIAPRO Enquiry: ${formData.get('inquiry')}`);
      formData.append('from_name', String(formData.get('name') ?? 'BELIAPRO Website'));

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData,
        });
        const result = await response.json();

        if (result.success) {
          status.textContent = 'Message sent! We will get back to you soon.';
          status.className = 'font-body-md text-center min-h-[1.5rem] text-primary-container';
          form.reset();
        } else {
          status.textContent = result.message || 'Something went wrong. Please try again.';
          status.className = 'font-body-md text-center min-h-[1.5rem] text-red-400';
        }
      } catch {
        status.textContent = 'Network error. Please try again later.';
        status.className = 'font-body-md text-center min-h-[1.5rem] text-red-400';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
      }
    };

    form.removeEventListener('submit', onSubmit);
    form.addEventListener('submit', onSubmit);
  }

  initContactForm();
  document.addEventListener('astro:page-load', initContactForm);
</script>
