---
import Layout from '../../layouts/Layout.astro';
import Reveal from '../../components/Reveal.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const featuredPost = posts.find((p) => p.data.featured) ?? posts[0];
const gridPosts = posts.filter((p) => p.id !== featuredPost?.id);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function formatShortDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<Layout
  title="News & Media | BELIAPRO"
  description="Latest news, updates, and activities from Kelab Belia Progresif Datuk Keramat (BELIAPRO)."
  image="/images/news.png"
>
  <main class="pt-32 pb-section-gap px-margin-mobile md:px-8 max-w-7xl mx-auto">
    <Reveal>
      <header class="mb-20 text-center md:text-left">
        <p class="font-label-caps text-label-caps text-primary-container mb-4 uppercase">News & Updates</p>
        <h1 class="text-display-responsive text-white tracking-tighter leading-none">
          BELIAPRO News.
        </h1>
        <p class="font-body-lg text-secondary max-w-2xl mt-6">
          Stay updated on our programmes, community activities, and youth development initiatives across Kuala Lumpur.
        </p>
      </header>
    </Reveal>

    {
      featuredPost && (
        <Reveal>
          <section class="mb-section-gap">
            <a
              href={`/news/${featuredPost.id}`}
              class="relative group flex flex-col justify-end min-h-[26rem] aspect-[3/4] md:min-h-0 md:aspect-[21/9] overflow-hidden rounded-[40px] glass-card hover:border-primary-container/30 transition-colors"
            >
              <img
                alt={featuredPost.data.title}
                class="absolute inset-0 w-full h-full object-cover object-center opacity-70 group-hover:scale-105 transition-transform duration-700"
                src={featuredPost.data.image}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-black/10" />
              <div class="relative z-10 px-6 pb-6 pt-8 md:px-16 md:pb-12 md:pt-16 bg-gradient-to-t from-black via-black/90 to-transparent">
                <div class="flex flex-wrap items-center gap-2 mb-3 md:mb-4">
                  <span class="bg-primary-container text-on-primary px-3 py-1.5 md:px-4 rounded-full font-label-caps text-[10px] md:text-xs font-bold tracking-widest">
                    FEATURED
                  </span>
                  <span class="text-white font-label-caps text-xs md:text-sm uppercase tracking-widest">
                    {formatDate(featuredPost.data.date)}
                  </span>
                </div>
                <h2 class="text-xl md:text-headline-responsive text-white mb-2 md:mb-4 leading-tight line-clamp-2 md:line-clamp-3">
                  {featuredPost.data.title}
                </h2>
                <p class="font-body-md md:font-body-lg text-white/70 line-clamp-2 max-w-2xl hidden sm:block">
                  {featuredPost.data.excerpt}
                </p>
              </div>
            </a>
          </section>
        </Reveal>
      )
    }

    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-24 gap-x-12">
      {
        gridPosts.map((post, i) => (
          <Reveal delay={i * 80}>
            <article class="flex flex-col group">
              <a href={`/news/${post.id}`} class="relative aspect-square overflow-hidden rounded-[32px] glass-card mb-8 block hover:border-primary-container/30 transition-colors">
                <img
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700"
                  src={post.data.image}
                />
              </a>
              <div class="space-y-4">
                <span class="text-white/40 font-label-caps text-xs uppercase tracking-widest">
                  {post.data.category} / {formatShortDate(post.data.date)}
                </span>
                <h3 class="text-headline-md-responsive text-white group-hover:text-primary-container transition-colors">
                  <a href={`/news/${post.id}`}>{post.data.title}</a>
                </h3>
                <p class="font-body-md text-white/60">{post.data.excerpt}</p>
              </div>
            </article>
          </Reveal>
        ))
      }
    </section>

    <Reveal>
      <div class="mt-section-gap flex justify-center">
        <a
          href="/news"
          class="border border-white/20 text-white px-12 py-4 rounded-full font-label-caps tracking-widest uppercase hover:bg-white hover:text-black transition-all duration-300"
        >
          View Archive
        </a>
      </div>
    </Reveal>
  </main>
</Layout>
