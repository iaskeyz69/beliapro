---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/Reveal.astro';

const programs = [
  {
    category: 'Leadership',
    title: 'Leadership & Entrepreneurship',
    description: 'Training programmes that develop leadership skills, entrepreneurial thinking, and the confidence to lead community initiatives.',
    icon: 'rocket_launch',
    features: ['Workshops & seminars', 'Mentorship sessions', 'Business skills training'],
  },
  {
    category: 'Culture',
    title: 'Culture & Heritage',
    description: 'Activities that celebrate Malaysian culture and heritage, fostering appreciation for our traditions and arts.',
    icon: 'palette',
    features: ['Cultural events', 'Heritage programmes', 'Arts & crafts'],
  },
  {
    category: 'Sports',
    title: 'Sports & Health',
    description: 'Promoting physical fitness, healthy lifestyles, and teamwork through sports and wellness activities.',
    icon: 'sports_soccer',
    features: ['Sports tournaments', 'Health awareness', 'Fitness activities'],
  },
  {
    category: 'Community',
    title: 'Community Development',
    description: 'Outreach programmes serving both urban and rural communities — building stronger neighbourhoods together.',
    icon: 'volunteer_activism',
    features: ['Urban outreach', 'Rural programmes', 'Volunteer projects'],
  },
  {
    category: 'Environment',
    title: 'Environment & Welfare',
    description: 'Initiatives focused on environmental care, social welfare, and spiritual development for holistic youth growth.',
    icon: 'eco',
    features: ['Environmental campaigns', 'Social welfare aid', 'Spiritual programmes'],
  },
  {
    category: 'Education',
    title: 'Education & Life Skills',
    description: 'Helping youth develop positive attitudes and practical skills to face life\'s challenges with confidence.',
    icon: 'menu_book',
    features: ['Life skills workshops', 'Education support', 'Positive values training'],
  },
];

const categories = ['All Programmes', 'Leadership', 'Culture', 'Sports', 'Community', 'Environment', 'Education'];
---

<Layout title="Programmes | BELIAPRO" description="BELIAPRO programmes in leadership, culture, sports, community development, environment, and life skills for Malaysian youth." image="/images/programs.png">
  <main class="pt-32 pb-section-gap">
    <section class="max-w-7xl mx-auto px-8 mb-24">
      <Reveal>
        <div class="inline-block bg-surface-container-high px-4 py-1.5 rounded-full mb-6">
          <span class="font-label-caps text-primary-container uppercase">Youth Development</span>
        </div>
        <h1 class="text-display-responsive text-white leading-none mb-8 max-w-4xl">Our Programmes.</h1>
        <p class="font-body-lg text-secondary max-w-2xl">
          BELIAPRO offers a wide range of programmes aligned with our constitution — promoting youth
          involvement in culture, environment, sports, health, spirituality, social welfare, leadership,
          skills, and entrepreneurship.
        </p>
      </Reveal>
    </section>

    <section class="max-w-7xl mx-auto px-8 mb-16">
      <Reveal>
        <div id="program-filters" class="flex flex-wrap gap-4">
          {
            categories.map((cat, i) => (
              <button
                type="button"
                data-filter={cat}
                class:list={[
                  'filter-btn px-8 py-3 rounded-full font-label-caps uppercase transition-colors',
                  i === 0
                    ? 'bg-primary-container text-on-primary'
                    : 'bg-surface-container-high text-on-surface hover:bg-surface-variant',
                ]}
              >
                {cat}
              </button>
            ))
          }
        </div>
      </Reveal>
    </section>

    <section class="max-w-7xl mx-auto px-8">
      <div id="program-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          programs.map((program, i) => (
            <Reveal delay={i * 80}>
              <div
                data-category={program.category}
                class="program-card bg-[#1A1A1A] rounded-[40px] p-10 border border-white/10 flex flex-col justify-between min-h-[420px] hover:border-primary-container/30 transition-colors h-full"
              >
                <div>
                  <div class="w-16 h-16 bg-primary-container rounded-2xl flex items-center justify-center mb-8">
                    <span class="material-symbols-outlined text-on-primary text-3xl">{program.icon}</span>
                  </div>
                  <span class="font-label-caps text-secondary mb-2 block uppercase">{program.category}</span>
                  <h3 class="text-headline-md-responsive text-white mb-4">{program.title}</h3>
                  <p class="font-body-md text-secondary mb-6">{program.description}</p>
                  <ul class="space-y-3">
                    {
                      program.features.map((feature) => (
                        <li class="flex items-center gap-3 text-on-surface">
                          <span class="material-symbols-outlined text-primary-container text-sm">check_circle</span>
                          <span class="font-body-md">{feature}</span>
                        </li>
                      ))
                    }
                  </ul>
                </div>
                <div class="pt-8 mt-auto border-t border-white/5">
                  <a
                    href="/contact"
                    class="block w-full text-center bg-white/5 text-white border border-white/10 px-6 py-4 rounded-full font-label-caps uppercase hover:bg-white/10 transition-colors"
                  >
                    Enquire
                  </a>
                </div>
              </div>
            </Reveal>
          ))
        }
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-8 mt-section-gap">
      <Reveal>
        <div class="bg-primary-container rounded-[40px] p-16 md:p-24 text-center">
          <h2 class="text-headline-responsive text-on-primary mb-8">Get Involved in Our Programmes.</h2>
          <p class="font-body-lg text-on-primary/80 max-w-2xl mx-auto mb-12">
            Whether you want to join a programme, volunteer, or partner with BELIAPRO — we'd love to hear from you.
          </p>
          <div class="flex flex-col md:flex-row gap-6 justify-center">
            <a href="/contact" class="bg-black text-white px-12 py-5 rounded-full font-label-caps uppercase tracking-widest hover:scale-105 transition-transform">Contact Us</a>
            <a href="/about" class="border-2 border-black/20 text-on-primary px-12 py-5 rounded-full font-label-caps uppercase tracking-widest hover:bg-black/5 transition-colors">About BELIAPRO</a>
          </div>
        </div>
      </Reveal>
    </section>
  </main>
</Layout>

<script>
  function initProgramFilters() {
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.program-card');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');

        buttons.forEach((b) => {
          b.classList.remove('bg-primary-container', 'text-on-primary');
          b.classList.add('bg-surface-container-high', 'text-on-surface');
        });
        btn.classList.remove('bg-surface-container-high', 'text-on-surface');
        btn.classList.add('bg-primary-container', 'text-on-primary');

        cards.forEach((card) => {
          const category = card.getAttribute('data-category');
          const show = filter === 'All Programmes' || category === filter;
          card.classList.toggle('program-card-hidden', !show);
        });
      });
    });
  }

  initProgramFilters();
  document.addEventListener('astro:page-load', initProgramFilters);
</script>
