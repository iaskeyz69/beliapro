# Web3Forms — use either name in Vercel (both work after the build-time fix):
# WEB3FORMS_ACCESS_KEY=your_access_key_here
# PUBLIC_WEB3FORMS_ACCESS_KEY=your_access_key_here
#
# In Vercel: Settings → Environment Variables → add for Production + Preview
# Then redeploy (Deployments → ⋯ → Redeploy) so the key is baked into the build.

WEB3FORMS_ACCESS_KEY=your_access_key_here
